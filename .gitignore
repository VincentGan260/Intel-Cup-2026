# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Virtual env
.venv/
venv/
env/

# 说明：不要在此忽略 scripts/、docs/、configs/、environment/ 等需协作的源码与文档。
# 若需共享 VS Code / JetBrains 工作区配置，也不要忽略整个 .vscode/ 或 .idea/（可只忽略含本机路径的私有文件）。

# OS
.DS_Store
Thumbs.db

# Runtime
logs/*.log
.env
# Ultralytics runtime outputs
runs/

# Downloaded demo assets
/bus.jpg

# 本地测试图（可提交少量样例；大文件不要放这里）
data/samples/**
!data/samples/
!data/samples/detection/
!data/samples/detection/.gitkeep

# 项目自产输出（JSON、整理后的结果等；当前 YOLO 可视化在 runs/）
outputs/**
!outputs/
!outputs/.gitkeep
!outputs/vision/
!outputs/vision/.gitkeep

# 模型权重（.pt、OpenVINO .xml/.bin、ONNX 等）不忽略，便于队友 clone 后按文档配环境即可跑。
# TensorRT .engine 等若体积过大可自行改为 LFS 或再加回忽略。
